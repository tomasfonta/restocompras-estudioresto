meta {
  name: 1 - Get Waiters
  type: http
  seq: 1
}

get {
  url: {{base_url}}/restaurantRequest/waiters
  auth: inherit
}

tests {
  test("Returns 200", function() {
    expect(res.status).to.equal(200);
  });

  test("Response is an array", function() {
    expect(res.body).to.be.an("array");
  });

  test("Each waiter has WaiterId and Name", function() {
    if (res.body.length > 0) {
      expect(res.body[0]).to.have.property("waiterId");
      expect(res.body[0]).to.have.property("name");
    }
  });
}
