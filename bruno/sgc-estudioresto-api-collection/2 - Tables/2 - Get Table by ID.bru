meta {
  name: 2 - Get Table by ID
  type: http
  seq: 2
}

get {
  url: {{base_url}}/restaurantRequest/tables/{{table_id}}
  auth: inherit
}

tests {
  test("Returns 200", function() {
    expect(res.status).to.equal(200);
  });

  test("Response contains TableId", function() {
    expect(res.body).to.have.property("tableId");
  });

  test("Response contains Status", function() {
    expect(res.body).to.have.property("status");
  });
}
