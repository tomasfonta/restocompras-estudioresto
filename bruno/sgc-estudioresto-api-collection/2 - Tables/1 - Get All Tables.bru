meta {
  name: 1 - Get All Tables
  type: http
  seq: 1
}

get {
  url: {{base_url}}/restaurantRequest/tables
  auth: inherit
}

script:post-response {
  if (res.status === 200 && Array.isArray(res.body) && res.body.length > 0 && res.body[0].tableId) {
    bru.setEnvVar("table_id", res.body[0].tableId);
  }
}

tests {
  test("Returns 200", function() {
    expect(res.status).to.equal(200);
  });

  test("Response is an array", function() {
    expect(res.body).to.be.an("array");
  });
}
